# Bookia API — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env (it's gitignored).

# ─── Database ───────────────────────────────────────────────
# Admin connection (migrations/DDL, bypasses RLS)
DATABASE_URL=postgres://bookia:bookia_pass@localhost:5432/bookia
# RLS-enforced runtime connection (bookia_app role, NOINHERIT, FORCE RLS)
DATABASE_URL_APP=postgres://bookia_app:bookia_app_pass@localhost:5432/bookia

# ─── Server ─────────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ─── LLM ────────────────────────────────────────────────────
# Provider: "deepseek" (requires DEEPSEEK_API_KEY) or "mock" (no key, for tests/eval)
LLM_PROVIDER=mock
# DeepSeek API key — REQUIRED if LLM_PROVIDER=deepseek.
# Get from https://platform.deepseek.com. Load via shell export or .env (gitignored).
# NEVER commit this value.
DEEPSEEK_API_KEY=
MODEL_ROUTER=deepseek-v4-flash
MODEL_RESPONDER=deepseek-v4-flash

# ─── Agent Kernel ───────────────────────────────────────────
# "true" enables V2 kernel (default, north star), "false" rolls back to V1 (temp)
AGENT_KERNEL_V2=true

# ─── Workers ────────────────────────────────────────────────
# Scheduler for reminders/reengagement/crm. false in tests, true in dev/prod.
WORKERS_ENABLED=false

# ─── Security ───────────────────────────────────────────────
# SSE stream signing secret for /api/sim/stream tenant-scoped tokens (B6).
# Generate with: openssl rand -hex 32
SSE_STREAM_SECRET=
# DEV_AUTH=true bypasses real auth (header-based tenant, dev only). B1 replaces this.
DEV_AUTH=true
AUTH_SECRET=dev-secret-not-used-in-mvp

# ─── Wompi Payments (sandbox by default, live post-MVP) ────
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_KEY=
WOMPI_SANDBOX=true
