{
  "name": "bookia-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:sql": "tsx src/db/run-sql-migrations.ts",
    "db:push": "drizzle-kit push",
    "seed": "tsx src/db/seed.ts",
    "seed:demo": "tsx src/db/seed-demo.ts",
    "import:tenant": "tsx src/db/import-tenant.ts",
    "smoke-test": "bash scripts/smoke-test.sh",
    "secrets:check": "bash scripts/check-secrets.sh",
    "test:v2:unit": "vitest run tests/v2-agent.test.ts tests/v2-memory-persistence.test.ts",
    "test:v2:integration": "vitest run tests/v2-memory-integration.test.ts tests/rls.test.ts",
    "eval:router-v1": "tsx src/agent/eval/runner.ts",
    "eval:router-v2": "tsx src/agent/v2/eval/v2-eval-runner.ts",
    "eval:v2:fast": "tsx src/agent/v2/eval/eval-runner.ts --fast --output markdown",
    "eval:v2:full": "tsx src/agent/v2/eval/eval-runner.ts --include-unreviewed --output json",
    "eval:v2:critical": "tsx src/agent/v2/eval/eval-runner.ts --critical-only --reviewed-only --output markdown",
    "eval:v2:golden": "tsx src/agent/v2/eval/eval-runner.ts --golden-only --output markdown",
    "eval:v2:cat": "tsx src/agent/v2/eval/eval-runner.ts --category"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.40.1",
    "hono": "^4.7.8",
    "postgres": "^3.4.5",
    "uuid": "^14.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
